generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@index([slug])
  @@map("categories")
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  brand       String
  categoryId  String?
  tags        String[]  @default([])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category    Category?       @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]

  @@index([slug])
  @@index([brand])
  @@index([categoryId])
  @@index([isActive, createdAt(sort: Desc)])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  position  Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  sku            String   @unique
  price          Int      // VND, stored as integer
  compareAtPrice Int?
  color          String?
  size           String?
  stock          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sku])
  @@index([color])
  @@index([size])
  @@map("product_variants")
}

model HeroBanner {
  id           String   @id @default(cuid())
  key          String   @unique
  titleLeft    String   @default("Jump")
  titleRight   String   @default("man")
  subtitle     String   @default("Giày Bóng Rổ")
  badge        String   @default("2021 PF")
  watermark    String   @default("JORDAN")
  productName  String   @default("JORDAN JUMPMAN 2021 PF")
  price        String   @default("3.200.000₫")
  priceLabel   String   @default("độc quyền")
  description  String   @default("Lấy cảm hứng từ thiết kế giày thi đấu Air Jordan mới nhất.")
  ctaPrimary   String   @default("Mua ngay")
  ctaSecondary String   @default("Thêm vào giỏ")
  ctaLink      String   @default("/products")
  slides       Json     @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("hero_banners")
}
